# AI Reasoning Engine Configuration
NODE_ENV=development

# AI Provider
AI_PROVIDER=openai
AI_API_KEY=your-api-key-here
AI_MODEL=gpt-4

# Confidence Thresholds
MIN_CONFIDENCE_THRESHOLD=0.6
HIGH_CONFIDENCE_THRESHOLD=0.85
UNCERTAINTY_FLAG_THRESHOLD=0.5

# Source Validation
REQUIRE_SOURCE_FOR_CLAIMS=true
MIN_SOURCES_PER_STEP=1

# Audit Trail
AUDIT_STORAGE=local
AUDIT_DATABASE_URL=postgresql://localhost:5432/reasoning_audit
AUDIT_RETENTION_DAYS=365

# Explanation
DEFAULT_EXPLANATION_DEPTH=detailed
MAX_ALTERNATIVES_SHOWN=3

# Logging
LOG_LEVEL=info
